/* components/empty-state/empty-state.wxss */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--page-padding);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: var(--font-size-h3);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.empty-action {
  height: 80rpx;
  padding: 0 48rpx;
  background: var(--color-primary);
  border-radius: 40rpx;
  color: #fff;
  font-size: var(--font-size-body);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-action:active {
  background: var(--color-primary-dark);
}
