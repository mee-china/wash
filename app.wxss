/* ==========================================
   「我想洗头」微信小程序 - 全局样式
   小清新 · 薄荷绿风格
   ========================================== */

/* --- CSS Variables (WXSS Custom Properties) --- */
page {
  /* 小清新主色调：薄荷绿 */
  --color-primary: #6EC6B8;
  --color-primary-dark: #52B0A2;
  --color-primary-light: #A8E0D6;
  --color-primary-bg: #EEF7F5;

  /* 辅助色 */
  --color-secondary: #D8E8E5;
  --color-accent: #F0B098;
  --color-accent-dark: #E09880;

  /* 功能色 */
  --color-success: #7FB069;
  --color-warning: #E8A838;
  --color-error: #D4735E;

  /* 背景色 - 偏冷白 */
  --color-bg: #F7FAF9;
  --color-card: #FFFFFF;
  --color-overlay: rgba(45, 52, 54, 0.5);

  /* 文字色 - 冷灰调 */
  --color-text: #2D3436;
  --color-text-secondary: #8E9EA5;
  --color-text-muted: #B0BEC5;
  --color-text-placeholder: #CFD8DC;

  /* 描边与分割 */
  --color-border: #E6EDF0;
  --color-border-light: #F0F4F5;

  /* 尺寸 */
  --page-padding: 32rpx;
  --card-radius: 24rpx;
  --card-radius-sm: 16rpx;
  --tag-radius: 8rpx;

  /* 字体 */
  --font-size-h1: 44rpx;
  --font-size-h2: 36rpx;
  --font-size-h3: 32rpx;
  --font-size-body: 28rpx;
  --font-size-sm: 24rpx;
  --font-size-xs: 22rpx;
  --font-size-tag: 20rpx;

  /* 阴影 */
  --shadow-card: 0 4rpx 24rpx rgba(45, 52, 54, 0.05);
  --shadow-card-hover: 0 8rpx 32rpx rgba(45, 52, 54, 0.08);
  --shadow-btn: 0 4rpx 16rpx rgba(110, 198, 184, 0.35);

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: var(--font-size-body);
  line-height: 1.6;
  box-sizing: border-box;
}

/* --- Reset --- */
view, text, image, scroll-view, swiper, button, input, textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}

button::after {
  display: none;
}

image {
  display: block;
}

/* --- Utility Classes --- */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* --- Button Presets --- */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-radius: 48rpx;
  color: #FFFFFF;
  font-size: var(--font-size-h3);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-btn);
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary--disabled {
  opacity: 0.5;
  box-shadow: none;
}

.btn-outline {
  height: 72rpx;
  padding: 0 32rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 36rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--color-card);
}

.btn-outline:active {
  background: var(--color-border-light);
}

.btn-text {
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  padding: 8rpx 16rpx;
}

.btn-text:active {
  color: var(--color-primary);
}

/* --- Card --- */
.card {
  background: var(--color-card);
  border-radius: var(--card-radius);
  box-shadow: var(--shadow-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

/* --- Tag --- */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--tag-radius);
  font-size: var(--font-size-tag);
  line-height: 1.4;
}

.tag--primary {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.tag--secondary {
  background: #F0F4F5;
  color: var(--color-text-secondary);
}

.tag--success {
  background: #E8F5E0;
  color: var(--color-success);
}

.tag--warning {
  background: #FFF3E0;
  color: var(--color-warning);
}

/* --- Price --- */
.price {
  color: var(--color-primary);
  font-weight: 700;
}

.price--original {
  color: var(--color-text-muted);
  text-decoration: line-through;
  font-weight: 400;
  font-size: var(--font-size-sm);
}

.price--large {
  font-size: var(--font-size-h2);
}

.price--small {
  font-size: var(--font-size-body);
}

/* --- Status Badge --- */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: var(--font-size-tag);
  font-weight: 500;
}

.badge--waiting {
  background: #FFF3E0;
  color: var(--color-warning);
}

.badge--ontheway {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.badge--serving {
  background: #E8F5E0;
  color: var(--color-success);
}

.badge--done {
  background: #F0F4F5;
  color: var(--color-text-muted);
}

.badge--cancelled {
  background: #F5F0EE;
  color: var(--color-text-muted);
}

/* --- Loading Skeleton --- */
.skeleton {
  background: linear-gradient(90deg, #E6EDF0 25%, #F0F4F5 50%, #E6EDF0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* --- Toast-like inline messages --- */
.message-bar {
  padding: 16rpx var(--page-padding);
  font-size: var(--font-size-sm);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.message-bar--error {
  background: #FFF0EE;
  color: var(--color-error);
}

.message-bar--info {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

/* --- Scrollbar --- */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}
