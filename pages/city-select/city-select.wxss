/* pages/city-select/city-select.wxss */
.page-city-select {
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx var(--page-padding);
  background: var(--color-card);
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--color-bg);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: var(--font-size-body);
  color: var(--color-text);
  height: 48rpx;
}

.search-clear {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding: 8rpx;
}

.search-clear:active {
  color: var(--color-text);
}

/* 搜索结果 */
.search-results {
  padding: 0 var(--page-padding);
}

.search-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--color-border-light);
}

.search-result-item:active {
  background: var(--color-bg);
  margin: 0 -16rpx;
  padding: 28rpx 16rpx;
}

.search-result-item.current .result-name {
  color: var(--color-primary);
  font-weight: 600;
}

.search-result-item.disabled {
  opacity: 0.4;
}

.result-name {
  font-size: var(--font-size-body);
  color: var(--color-text);
}

.result-status {
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
}

/* Section */
.section-header {
  font-size: var(--font-size-sm);
  color: var(--color-text-muted);
  padding: 28rpx var(--page-padding) 12rpx;
}

/* GPS 定位 */
.city-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx var(--page-padding);
  background: var(--color-card);
  margin: 0 var(--page-padding);
  border-radius: var(--card-radius);
}

.gps-row:active {
  background: var(--color-bg);
}

.gps-icon {
  font-size: 32rpx;
}

.gps-city {
  flex: 1;
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text);
}

.gps-badge {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 热门城市 */
.hot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 var(--page-padding);
}

.hot-item {
  width: calc((100% - 48rpx) / 4);
  text-align: center;
  padding: 20rpx 0;
  background: var(--color-card);
  border-radius: var(--card-radius-sm);
  font-size: var(--font-size-body);
  color: var(--color-text);
  box-shadow: var(--shadow-card);
}

.hot-item:active {
  background: var(--color-primary-bg);
}

.hot-item.current {
  background: var(--color-primary);
  color: #fff;
}

/* 字母分组 */
.city-groups {
  padding: 0 var(--page-padding) 40rpx;
}

.city-group {
  margin-top: 20rpx;
}

.group-letter {
  font-size: var(--font-size-h2);
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.group-list {
  background: var(--color-card);
  border-radius: var(--card-radius);
}

.group-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  font-size: var(--font-size-body);
  color: var(--color-text);
  border-bottom: 2rpx solid var(--color-border-light);
}

.group-item:last-child {
  border-bottom: none;
}

.group-item:active {
  background: var(--color-bg);
}

.group-item.current {
  color: var(--color-primary);
  font-weight: 600;
}

.group-item.disabled {
  color: var(--color-text-muted);
}

.item-badge {
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
}
