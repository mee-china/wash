/* pages/master-list/master-list.wxss */
.page-master-list {
  min-height: 100vh;
}

/* ===== 筛选栏 ===== */
.filter-bar {
  display: flex;
  background: var(--color-card);
  padding: 16rpx var(--page-padding);
  gap: 8rpx;
  border-bottom: 2rpx solid var(--color-border-light);
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-border-light);
}

.filter-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

/* ===== 服务标签 ===== */
.service-tag-bar {
  padding: 16rpx var(--page-padding);
}

.service-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  font-size: var(--font-size-sm);
}

.tag-close {
  font-size: 20rpx;
}

/* ===== 列表 ===== */
.master-list {
  padding: 16rpx var(--page-padding);
}

.master-count {
  font-size: var(--font-size-sm);
  color: var(--color-text-muted);
  margin-bottom: 16rpx;
}

/* ===== 骨架屏 ===== */
.skeleton-list {
  padding: var(--page-padding);
}

.skeleton-master-card {
  width: 100%;
  height: 200rpx;
  border-radius: var(--card-radius);
  margin-bottom: 20rpx;
}

/* ===== 错误态 ===== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx var(--page-padding);
}

.error-text {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.btn-retry {
  width: 240rpx;
  height: 72rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: 36rpx;
  color: var(--color-primary);
  font-size: var(--font-size-body);
  display: flex;
  align-items: center;
  justify-content: center;
}
