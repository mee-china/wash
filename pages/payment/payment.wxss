/* pages/payment/payment.wxss */
.page-payment {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 200rpx;
}

/* ===== 成功遮罩 ===== */
.success-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(45, 31, 20, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-card {
  background: var(--color-card);
  border-radius: var(--card-radius);
  padding: 60rpx 80rpx;
  text-align: center;
  animation: popIn 0.3s ease-out;
}

@keyframes popIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.success-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.success-title {
  display: block;
  font-size: var(--font-size-h2);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ===== 订单摘要 ===== */
.order-summary {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx var(--page-padding) 32rpx;
}

.summary-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: var(--font-size-h2);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.summary-id {
  font-size: var(--font-size-sm);
  color: var(--color-text-muted);
}

/* ===== 支付区块 ===== */
.pay-section {
  margin: 0 var(--page-padding) 20rpx;
  background: var(--color-card);
  border-radius: var(--card-radius);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.pay-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.pay-title {
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text);
}

.pay-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.pay-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.pay-value {
  font-size: var(--font-size-sm);
  color: var(--color-text);
  font-weight: 500;
}

.pay-divider {
  height: 2rpx;
  background: var(--color-border-light);
  margin: 12rpx 0;
}

.pay-amount-row {
  padding: 4rpx 0;
}

.pay-amount-label {
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text);
}

.price--huge {
  font-size: var(--font-size-h1);
  font-weight: 800;
}

/* ===== 支付方式 ===== */
.pay-method {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.method-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.method-icon {
  font-size: 40rpx;
}

.method-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.method-name {
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text);
}

.method-desc {
  font-size: var(--font-size-xs);
  color: var(--color-success);
}

.method-checked {
  width: 36rpx;
  height: 36rpx;
  background: var(--color-success);
  border-radius: 50%;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 提示 ===== */
.pay-notice {

}

.notice-title {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.notice-text {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  line-height: 1.8;
}

/* ===== 操作按钮 ===== */
.pay-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-card);
  padding: 20rpx var(--page-padding);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.pay-cancel {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-muted);
  font-size: var(--font-size-sm);
  margin-top: 12rpx;
}

.pay-cancel:active {
  color: var(--color-text);
}
