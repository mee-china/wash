/* pages/order-detail/order-detail.wxss */
.page-order-detail {
  padding-bottom: 40rpx;
}

/* ===== 状态追踪 ===== */
.track-section {
  background: var(--color-card);
  margin: 0 var(--page-padding) 20rpx;
  border-radius: var(--card-radius);
  padding: 32rpx 28rpx;
  box-shadow: var(--shadow-card);
}

.track-steps {
  display: flex;
  justify-content: space-between;
  position: relative;
}

.track-steps::before {
  content: '';
  position: absolute;
  top: 18rpx;
  left: 40rpx;
  right: 40rpx;
  height: 4rpx;
  background: var(--color-border);
  z-index: 0;
}

.track-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
  z-index: 1;
  width: 16%;
}

.track-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  background: var(--color-border-light);
  color: var(--color-text-muted);
}

.track-step.done .track-dot {
  background: var(--color-success);
  color: #fff;
}

.track-step.active .track-dot {
  background: var(--color-primary);
  color: #fff;
  box-shadow: 0 0 0 8rpx rgba(232, 131, 90, 0.2);
}

.track-label {
  font-size: var(--font-size-tag);
  color: var(--color-text-muted);
  text-align: center;
}

.track-step.done .track-label {
  color: var(--color-success);
}

.track-step.active .track-label {
  color: var(--color-primary);
  font-weight: 600;
}

/* 等待接单 */
.track-waiting {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.waiting-text {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.waiting-timer {
  display: inline-block;
  font-size: var(--font-size-h1);
  font-weight: 800;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 8rpx 32rpx;
  border-radius: 16rpx;
  font-variant-numeric: tabular-nums;
}

/* 位置追踪 */
.track-location {
  margin-top: 20rpx;
}

.map-placeholder {
  height: 200rpx;
  background: var(--color-bg);
  border-radius: var(--card-radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 48rpx;
  color: var(--color-text-muted);
}

.map-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.location-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 0;
}

.location-eta {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: 600;
}

/* ===== 信息卡片 ===== */
.info-card {
  background: var(--color-card);
  margin: 0 var(--page-padding) 20rpx;
  border-radius: var(--card-radius);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.info-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-master {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.info-master-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-master-name {
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text);
}

.info-service-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
}

/* 订单信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 2rpx solid var(--color-border-light);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-muted);
  flex-shrink: 0;
  width: 140rpx;
}

.info-val {
  font-size: var(--font-size-sm);
  color: var(--color-text);
  text-align: right;
  flex: 1;
}

/* ===== 操作区域 ===== */
.action-area {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 0 var(--page-padding);
  margin-top: 8rpx;
}

/* ===== 取消弹窗 ===== */
.cancel-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: none;
}

.cancel-modal.show {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.cancel-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-overlay);
}

.cancel-sheet {
  position: relative;
  z-index: 1;
  background: var(--color-card);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx var(--page-padding);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.cancel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.cancel-title {
  font-size: var(--font-size-h3);
  font-weight: 700;
  color: var(--color-text);
}

.cancel-close {
  font-size: 32rpx;
  color: var(--color-text-muted);
  padding: 8rpx;
}

.cancel-hint {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.cancel-reasons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.cancel-reason {
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid var(--color-border-light);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.cancel-reason.active {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-weight: 600;
}

.cancel-note {
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  margin-bottom: 24rpx;
  text-align: center;
}

/* ===== 骨架屏 ===== */
.skeleton-block {
  padding: var(--page-padding);
}

.skeleton-detail-card {
  width: 100%;
  height: 300rpx;
  border-radius: var(--card-radius);
  margin-bottom: 20rpx;
}
