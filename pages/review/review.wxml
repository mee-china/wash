<!-- pages/review/review.wxml -->
<view class="page-review">

  <!-- 已提交 -->
  <block wx:if="{{submitted}}">
    <view class="submitted-state">
      <text class="submitted-icon">✅</text>
      <text class="submitted-title">评价已提交</text>
      <text class="submitted-desc">感谢您的反馈，这将帮助更多用户做出选择</text>
    </view>
  </block>

  <!-- 评价表单 -->
  <block wx:else>

    <!-- 服务摘要 -->
    <view class="review-summary" wx:if="{{order}}">
      <view class="summary-avatar" style="background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));">
        <text>{{order.masterAvatar}}</text>
      </view>
      <view class="summary-info">
        <text class="summary-name">{{order.masterName}}</text>
        <text class="summary-service">{{order.serviceName}} · {{order.time}}</text>
      </view>
    </view>

    <!-- 评分 -->
    <view class="review-section">
      <text class="review-section-title">整体评分</text>
      <view class="rating-area">
        <rating-stars rating="{{rating}}" size="64" interactive="{{true}}" bindchange="onRatingChange" />
        <text class="rating-hint">
          <block wx:if="{{rating === 0}}">点击评分</block>
          <block wx:elif="{{rating <= 2}}">不太满意</block>
          <block wx:elif="{{rating === 3}}">一般</block>
          <block wx:elif="{{rating === 4}}">满意</block>
          <block wx:elif="{{rating === 5}}">非常满意</block>
        </text>
      </view>
    </view>

    <!-- 标签选择 -->
    <view class="review-section">
      <text class="review-section-title">标签（选填）</text>
      <view class="tag-grid">
        <view
          class="tag-option {{selectedTags.includes(item) ? 'active' : ''}}"
          wx:for="{{tagOptions}}"
          wx:key="*this"
          data-tag="{{item}}"
          bindtap="onTagToggle"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 文字评价 -->
    <view class="review-section">
      <text class="review-section-title">文字评价（选填）</text>
      <view class="text-area-wrap">
        <textarea
          class="review-textarea"
          placeholder="分享您的体验，帮助其他用户选择..."
          value="{{reviewText}}"
          maxlength="200"
          bindinput="onTextInput"
        ></textarea>
        <text class="text-count">{{textCount}}/200</text>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="review-section">
      <text class="review-section-title">图片（选填，最多3张）</text>
      <view class="image-grid">
        <view
          class="image-item image-upload"
          wx:if="{{images.length < 3}}"
          bindtap="onUploadImage"
        >
          <text class="upload-icon">+</text>
        </view>
        <view class="image-item" wx:for="{{images}}" wx:key="index">
          <image class="review-image" src="{{item}}" mode="aspectFill" />
          <view class="image-remove" data-index="{{index}}" bindtap="onRemoveImage">✕</view>
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="review-actions safe-bottom">
      <button class="btn-text" bindtap="onSkip">跳过评价</button>
      <button
        class="btn-primary {{isSubmitting ? 'btn-primary--disabled' : ''}}"
        disabled="{{isSubmitting}}"
        bindtap="onSubmit"
      >
        {{isSubmitting ? '提交中...' : '提交评价'}}
      </button>
    </view>

  </block>

</view>
