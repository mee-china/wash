/* pages/review/review.wxss */
.page-review {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* ===== 已提交 ===== */
.submitted-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx var(--page-padding);
}

.submitted-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.submitted-title {
  font-size: var(--font-size-h2);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.submitted-desc {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

/* ===== 服务摘要 ===== */
.review-summary {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx var(--page-padding);
  background: var(--color-card);
}

.summary-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

.summary-info {
  flex: 1;
}

.summary-name {
  display: block;
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text);
}

.summary-service {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== 评价区块 ===== */
.review-section {
  margin: 0 var(--page-padding) 20rpx;
  background: var(--color-card);
  border-radius: var(--card-radius);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.review-section-title {
  display: block;
  font-size: var(--font-size-body);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

/* 评分 */
.rating-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.rating-hint {
  font-size: var(--font-size-body);
  color: var(--color-text-secondary);
}

/* 标签 */
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  background: var(--color-border-light);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.tag-option.active {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-weight: 600;
  border: 2rpx solid var(--color-primary);
}

/* 文字 */
.text-area-wrap {
  position: relative;
}

.review-textarea {
  width: 100%;
  height: 200rpx;
  background: var(--color-bg);
  border-radius: var(--card-radius-sm);
  padding: 20rpx;
  font-size: var(--font-size-body);
  color: var(--color-text);
  resize: none;
  line-height: 1.6;
}

.text-count {
  position: absolute;
  bottom: 12rpx;
  right: 16rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
}

/* 图片 */
.image-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--card-radius-sm);
  overflow: hidden;
  position: relative;
}

.image-upload {
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--color-border);
}

.upload-icon {
  font-size: 48rpx;
  color: var(--color-text-muted);
}

.review-image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--color-overlay);
  border-radius: 50%;
  color: #fff;
  font-size: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 操作按钮 ===== */
.review-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-card);
  padding: 20rpx var(--page-padding);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.review-actions .btn-text {
  flex-shrink: 0;
  padding: 24rpx;
}

.review-actions .btn-primary {
  flex: 1;
}
